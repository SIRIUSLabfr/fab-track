# Supabase-Zugangsdaten — findest du im Supabase-Dashboard unter
# Project Settings → API → "Project URL" und "anon / public" key.
# Diese Datei nach ".env" kopieren und Werte eintragen.
# WICHTIG: Dieselben Variablen auch in Netlify hinterlegen
# (Site settings → Environment variables).
#
# Hinweis: VITE_SUPABASE_URL ist die Basis-Projekt-URL OHNE Pfad-Anhang
# (also https://dein-projekt.supabase.co — NICHT .../rest/v1/).

VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-public-key
